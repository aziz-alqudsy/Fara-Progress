# ====== Telegram Reminder Bot - konfigurasi ======

# WAJIB: token dari @BotFather
BOT_TOKEN=123456:ABC-your-token-here

# Lokasi file database SQLite (relatif terhadap folder project).
# Dipakai HANYA jika DATABASE_URL kosong (mode lokal / tanpa Postgres).
DB_PATH=reminder.db

# PostgreSQL (mis. Neon/Supabase) — ISI ini di produksi agar data persisten
# walau Render redeploy. Jika diisi, DB_PATH diabaikan dan bot pakai Postgres.
# Format: postgresql://user:password@host/dbname?sslmode=require
# DATABASE_URL=

# Timezone default untuk parsing jadwal (lihat daftar IANA tz)
DEFAULT_TZ=Asia/Jakarta

# Jam (0-23) untuk reminder harian ke pengguna yang belum update progress
NAG_HOUR=9

# Mode jalan: "webhook" (produksi) atau "polling" (lokal/testing)
RUN_MODE=webhook

# ====== Pengaturan webhook (hanya dipakai jika RUN_MODE=webhook) ======
# URL HTTPS publik yang menunjuk ke bot ini (tanpa trailing slash).
# Contoh saat lokal pakai cloudflared/ngrok: https://xxxx.trycloudflare.com
WEBHOOK_URL=https://your-domain.example.com

# Alamat & port yang didengarkan server lokal
WEBHOOK_LISTEN=0.0.0.0
WEBHOOK_PORT=8443

# Path rahasia untuk endpoint webhook (boleh disamakan dengan token)
WEBHOOK_PATH=telegram

# Secret token opsional (Telegram mengirim header X-Telegram-Bot-Api-Secret-Token)
WEBHOOK_SECRET=
